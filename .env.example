# ==========================================================================
#  LinkedIn Post Studio — environment configuration
#  Copy to `.env.local` (Next.js) and `.env` (worker / drizzle-kit) and fill in.
#  NOTHING here points at a paid API. The only external service is LinkedIn.
# ==========================================================================

# ---- Core ----------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# ---- Database (self-hosted Postgres) -------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/linkedin_studio

# ---- Auth.js -------------------------------------------------------------
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=replace-me-with-a-32-byte-random-string
AUTH_URL=http://localhost:3000

# ---- Token encryption (AES-256-GCM) --------------------------------------
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
# This is NOT in the database — it lives only here / in the host keystore.
TOKEN_ENC_KEY=replace-me-with-a-base64-32-byte-key

# ---- LinkedIn OAuth (Developer app) --------------------------------------
# Products required: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Monthly-versioned API. [VERIFY] the current value in LinkedIn's docs.
LINKEDIN_API_VERSION=202506

# ---- Local AI: Ollama (captions) -----------------------------------------
# Run Ollama natively on Windows; from Docker use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CAPTION_MODEL=qwen2.5:14b

# ---- Local AI: ComfyUI (images, Stable Diffusion / SDXL) -----------------
# Run ComfyUI natively on Windows; from Docker use http://host.docker.internal:8188
COMFYUI_BASE_URL=http://localhost:8188
# Must match a checkpoint file present in ComfyUI/models/checkpoints/
COMFYUI_SDXL_CHECKPOINT=sd_xl_base_1.0.safetensors

# ---- Gemini (free-tier text for captions/topics) -------------------------
# Free API key from https://aistudio.google.com/apikey  (text is free-tier; image gen is paid)
GEMINI_API_KEY=

# ---- Object storage (MinIO, S3-compatible) -------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=post-images
# Public base URL used in <img> src and emails (MinIO console/proxy or app proxy)
S3_PUBLIC_URL=http://localhost:9000/post-images

# ---- Email (SMTP via Nodemailer) -----------------------------------------
# Any free SMTP: your mailbox (app password) or a self-hosted MTA.
SMTP_URL=smtp://user:pass@smtp.example.com:587
EMAIL_FROM="LinkedIn Post Studio <daily@yourdomain.com>"

# ---- Generation defaults -------------------------------------------------
# Local hour (in each user's timezone) the daily draft is prepared.
DEFAULT_GENERATION_HOUR=7
